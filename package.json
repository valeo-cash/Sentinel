{
  "name": "@x402sentinel/x402",
  "version": "0.1.4",
  "description": "Enterprise audit, compliance, and budget enforcement for x402 payments",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./dashboard": {
      "import": {
        "types": "./dist/dashboard.d.ts",
        "default": "./dist/dashboard.js"
      },
      "require": {
        "types": "./dist/dashboard.d.cts",
        "default": "./dist/dashboard.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "peerDependencies": {
    "@x402/core": ">=0.1.0",
    "@x402/fetch": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@x402/fetch": {
      "optional": true
    },
    "@x402/core": {
      "optional": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.1",
    "next": "^15.5.12",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "x402",
    "payments",
    "audit",
    "compliance",
    "budget",
    "ai-agents",
    "usdc"
  ],
  "author": "Valeo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/valeo-cash/Sentinel"
  },
  "homepage": "https://sentinel.valeocash.com"
}
