# Local development (default, no config needed)
# DATABASE_URL=file:./data/sentinel.db

# Production (Turso)
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=your-token

# Auth (required for wallet/email login)
# JWT_SECRET=<random 64-char hex string — run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">
# RESEND_API_KEY=re_xxxxxxxx  (from resend.com, for magic link emails)
# NEXT_PUBLIC_APP_URL=https://sentinel.valeocash.com
